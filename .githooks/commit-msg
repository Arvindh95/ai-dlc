#!/bin/sh
# Require every commit to cite at least one work-item ID.
# Exception: the template-instantiation "Initial commit" (auto-generated by
# GitHub's "Use this template" or by user-on-ZIP-bootstrap) is exempt so
# fresh repos can boot without a manual override.
first_line="$(head -n 1 "$1")"
case "$first_line" in
    "Initial commit"|"Initial commit from "*)
        exit 0
        ;;
esac
if ! grep -qE '(REQ|TASK|FB|INC|CR|DEC)-[0-9]+' "$1"; then
    echo "ERROR: commit message must reference at least one work-item ID (REQ/TASK/FB/INC/CR/DEC)"
    exit 1
fi
